NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=replace_with_a_secure_long_random_secret
JWT_EXPIRES_IN=1d

# Aiven / cloud PostgreSQL connection string.
# Use sslmode=require for Aiven PostgreSQL.
# The schema parameter keeps this app isolated from existing public tables.
DATABASE_URL="postgresql://avnadmin:<password>@<host>:<port>/<database>?sslmode=require&schema=reliability_dashboard"
