generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum ProjectCategory {
  RAC
  CAG
}

enum ProjectSubcategory {
  HP
  SRICITY
  VRF
  DUCTED
  IBG
  CHILLERS
}

enum ProjectType {
  ODU
  IDU
  DRIVE
  COMPONENT
}

enum ProjectStatus {
  NOT_STARTED
  ONGOING
  COMPLETED
  ON_HOLD
  DROPPED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole @default(EMPLOYEE)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  reliabilityForms ReliabilityRequirementForm[]
  generatedReports GeneratedReport[]
  authSessions     AuthSession[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model Project {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @db.VarChar(255)
  category          ProjectCategory
  subcategory       ProjectSubcategory
  type              ProjectType
  status            ProjectStatus      @default(NOT_STARTED)
  priority          ProjectPriority    @default(MEDIUM)
  startDate         DateTime           @db.Date
  endDate           DateTime           @db.Date
  location          String             @db.VarChar(255)
  description       String?            @db.Text
  createdBy         String             @db.Uuid
  reliabilityFormId String?            @unique @db.Uuid
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  creator         User                        @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  reliabilityForm ReliabilityRequirementForm? @relation(fields: [reliabilityFormId], references: [id], onDelete: SetNull)
  reports         GeneratedReport[]

  @@index([category])
  @@index([subcategory])
  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([startDate])
  @@index([endDate])
  @@index([createdBy])
  @@index([category, subcategory, type])
  @@index([status, priority])
  @@index([name])
  @@map("projects")
}

model ReliabilityRequirementForm {
  id                   String             @id @default(uuid()) @db.Uuid
  projectName          String             @db.VarChar(255)
  category             ProjectCategory
  subcategory          ProjectSubcategory
  type                 ProjectType
  requestDate          DateTime           @default(now()) @db.Date
  reliabilityStartDate DateTime           @db.Date
  reliabilityEndDate   DateTime           @db.Date
  status               ProjectStatus      @default(NOT_STARTED)
  priority             ProjectPriority    @default(MEDIUM)
  location             String             @db.VarChar(255)
  remarks              String?            @db.Text
  createdBy            String             @db.Uuid
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  creator User              @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  project Project?
  reports GeneratedReport[]

  @@index([category])
  @@index([subcategory])
  @@index([status])
  @@index([priority])
  @@index([requestDate(sort: Desc)])
  @@index([reliabilityStartDate])
  @@index([reliabilityEndDate])
  @@index([createdBy])
  @@index([requestDate(sort: Desc), priority])
  @@map("reliability_requirement_forms")
}

model GeneratedReport {
  id                String       @id @default(uuid()) @db.Uuid
  reportName        String       @db.VarChar(255)
  reportType        String       @db.VarChar(100)
  storagePath       String       @db.VarChar(500)
  fileFormat        String       @db.VarChar(50)
  fileSize          Int?
  status            ReportStatus @default(PENDING)
  projectId         String?      @db.Uuid
  reliabilityFormId String?      @db.Uuid
  generatedBy       String       @db.Uuid
  metadata          Json?
  generatedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  project         Project?                    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reliabilityForm ReliabilityRequirementForm? @relation(fields: [reliabilityFormId], references: [id], onDelete: SetNull)
  generator       User                        @relation(fields: [generatedBy], references: [id], onDelete: Restrict)

  @@index([reportType])
  @@index([status])
  @@index([projectId])
  @@index([reliabilityFormId])
  @@index([generatedBy])
  @@index([generatedAt])
  @@map("generated_reports")
}
