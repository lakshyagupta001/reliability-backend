generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum ProjectCategory {
  RAC
  CAG
}

enum ProjectSubcategory {
  HP
  SRICITY
  VRF
  DUCTED
  IBG
  CHILLERS
}

enum ProjectType {
  ODU
  IDU
  DRIVE
  COMPONENT
}

enum ProjectStatus {
  NOT_STARTED
  ONGOING
  COMPLETED
  ON_HOLD
  DROPPED
}

enum ProjectScope {
  DOMESTIC
  OVERSEAS
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum DocumentType {
  DESIGN_DOCUMENT
  HARDWARE_EVALUATION_REPORT
  LOGIC_EVALUATION_REPORT
  CHANGE_POINT_DOCUMENT
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole @default(EMPLOYEE)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  generatedReports GeneratedReport[]
  authSessions     AuthSession[]
  uploadedDocuments ProjectDocument[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model Project {
  id                  String           @id @default(uuid()) @db.Uuid
  name                String           @db.VarChar(255)
  category            ProjectCategory
  subcategory         ProjectSubcategory
  type                ProjectType
  status              ProjectStatus    @default(NOT_STARTED)
  startDate           DateTime         @db.Date
  endDate             DateTime         @db.Date
  location            String           @db.VarChar(255)

  // Basic Details
  partName                   String?   @db.VarChar(255)
  modelName                  String?   @db.VarChar(255)
  projectPIC                 String?   @db.VarChar(255)
  projectScope               ProjectScope?
  applicableCompliance       String?   @db.VarChar(500)

  sampleSubmissionDate       DateTime? @db.Date
  massProductionDate         DateTime? @db.Date

  partSampleCount            Int?
  productSampleCount         Int?

  projectPriorityScale       String?   @db.VarChar(50)

  // Technical Details
  operatingVoltageRange      String?   @db.VarChar(100)
  ambientOperatingRange      String?   @db.VarChar(100)

  iduHardwareVersion         String?   @db.VarChar(100)
  oduHardwareVersion         String?   @db.VarChar(100)

  iduFirmwareVersion        String?   @db.VarChar(100)
  oduFirmwareVersion        String?   @db.VarChar(100)

  partNumberAndMake          String?   @db.Text
  technicalDataSheetReference String?  @db.Text

  maximumPipingLength        String?   @db.VarChar(100)
  maximumCommunicationWireLength String? @db.VarChar(100)

  oduFanMotorDetails         String?   @db.Text
  iduFanMotorDetails         String?   @db.Text

  compressorDetails         String?   @db.Text

  refrigerantName           String?   @db.VarChar(100)
  refrigerantQuantity       String?   @db.VarChar(50)

  createdBy                  String    @db.Uuid
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  creator           User                       @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  reports           GeneratedReport[]
  documents         ProjectDocument[]

  @@index([category])
  @@index([subcategory])
  @@index([type])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([createdBy])
  @@index([category, subcategory, type])
  @@index([name])
  @@map("projects")
}

model ProjectDocument {
  id            String       @id @default(uuid()) @db.Uuid
  projectId     String       @db.Uuid
  documentType  DocumentType
  fileName      String       @db.VarChar(255)
  fileUrl       String       @db.VarChar(500)
  fileSize      Int?
  mimeType      String?      @db.VarChar(100)
  uploadedBy    String       @db.Uuid
  uploadedAt    DateTime     @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([documentType])
  @@index([uploadedBy])
  @@map("project_documents")
}

model GeneratedReport {
  id          String       @id @default(uuid()) @db.Uuid
  reportName  String       @db.VarChar(255)
  reportType  String       @db.VarChar(100)
  storagePath String       @db.VarChar(500)
  fileFormat  String       @db.VarChar(50)
  fileSize    Int?
  status      ReportStatus @default(PENDING)
  projectId   String?      @db.Uuid
  generatedBy String       @db.Uuid
  metadata    Json?
  generatedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  generator User    @relation(fields: [generatedBy], references: [id], onDelete: Restrict)

  @@index([reportType])
  @@index([status])
  @@index([projectId])
  @@index([generatedBy])
  @@index([generatedAt])
  @@map("generated_reports")
}
