generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StatusMaster {
  id            String                 @id @default(uuid()) @db.Uuid
  code          String                 @unique @db.VarChar(50)
  displayName   String                 @db.VarChar(100)
  color         String                 @default("#6B7280") @db.VarChar(20)
  isActive      Boolean                @default(true)
  isSystem      Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  statusHistory ProjectStatusHistory[]
  projects      Project[]

  @@index([code])
  @@index([isActive])
  @@index([isSystem])
  @@map("status_master")
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique @db.VarChar(255)
  password          String            @db.VarChar(255)
  role              UserRole          @default(EMPLOYEE)
  firstName         String            @db.VarChar(100)
  lastName          String            @db.VarChar(100)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  authSessions      AuthSession[]
  uploadedDocuments ProjectDocument[]
  projects          Project[]
  reports           reports[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

model Project {
  id                             String                 @id @default(uuid()) @db.Uuid
  name                           String                 @db.VarChar(255)
  startDate                      DateTime               @db.Date
  endDate                        DateTime               @db.Date
  location                       String                 @db.VarChar(255)
  partName                       String?                @db.VarChar(255)
  modelName                      String?                @db.VarChar(255)
  projectPIC                     String?                @db.VarChar(255)
  projectScope                   ProjectScope?
  applicableCompliance           String?                @db.VarChar(500)
  sampleSubmissionDate           DateTime?              @db.Date
  massProductionDate             DateTime?              @db.Date
  partSampleCount                Int?
  productSampleCount             Int?
  projectPriorityScale           String?                @db.VarChar(50)
  operatingVoltageRange          String?                @db.VarChar(100)
  ambientOperatingRange          String?                @db.VarChar(100)
  iduHardwareVersion             String?                @db.VarChar(100)
  oduHardwareVersion             String?                @db.VarChar(100)
  iduFirmwareVersion             String?                @db.VarChar(100)
  oduFirmwareVersion             String?                @db.VarChar(100)
  partNumberAndMake              String?
  technicalDataSheetReference    String?
  maximumPipingLength            String?                @db.VarChar(100)
  maximumCommunicationWireLength String?                @db.VarChar(100)
  oduFanMotorDetails             String?
  iduFanMotorDetails             String?
  compressorDetails              String?
  refrigerantName                String?                @db.VarChar(100)
  refrigerantQuantity            String?                @db.VarChar(50)
  createdBy                      String                 @db.Uuid
  createdAt                      DateTime               @default(now())
  updatedAt                      DateTime               @updatedAt
  categoryId                     String                 @db.Uuid
  statusId                       String                 @db.Uuid
  statusRemark                   String?                @db.VarChar(1000)
  subcategoryId                  String                 @db.Uuid
  typeId                         String                 @db.Uuid
  documents                      ProjectDocument[]
  statusHistory                  ProjectStatusHistory[]
  category                       categories             @relation("ProjectCategory", fields: [categoryId], references: [id])
  creator                        User                   @relation(fields: [createdBy], references: [id])
  status                         StatusMaster           @relation(fields: [statusId], references: [id])
  subcategory                    subcategories          @relation("ProjectSubcategory", fields: [subcategoryId], references: [id])
  type                           types                  @relation("ProjectType", fields: [typeId], references: [id])
  reports                        reports[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([typeId])
  @@index([statusId])
  @@index([startDate])
  @@index([endDate])
  @@index([createdBy])
  @@index([name])
  @@map("projects")
}

model ProjectDocument {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  fileName     String   @db.VarChar(255)
  fileUrl      String   @db.VarChar(500)
  fileSize     Int?
  mimeType     String?  @db.VarChar(100)
  uploadedBy   String   @db.Uuid
  uploadedAt   DateTime @default(now())
  originalName String   @db.VarChar(255)
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader     User     @relation(fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@index([uploadedBy])
  @@map("project_documents")
}

model ProjectStatusHistory {
  id        String       @id @default(uuid()) @db.Uuid
  projectId String       @db.Uuid
  statusId  String       @db.Uuid
  remark    String?      @db.VarChar(1000)
  changedBy String       @db.Uuid
  changedAt DateTime     @default(now())
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    StatusMaster @relation(fields: [statusId], references: [id])

  @@index([projectId])
  @@index([statusId])
  @@index([changedAt])
  @@map("project_status_history")
}

model categories {
  id                 String          @id @db.Uuid
  name               String          @db.VarChar(100)
  code               String          @unique @db.VarChar(50)
  description        String?         @db.VarChar(500)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime
  projectsAsCategory Project[]       @relation("ProjectCategory")
  subcategories      subcategories[]

  @@index([code])
  @@index([isActive])
}

model reports {
  id           String     @id @db.Uuid
  title        String     @db.VarChar(255)
  format       String     @db.VarChar(50)
  formatNumber String?    @db.VarChar(100)
  reportNumber String?    @db.VarChar(100)
  data         Json
  createdBy    String     @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  projectId    String     @db.Uuid
  type         ReportType
  users        User       @relation(fields: [createdBy], references: [id])
  projects     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([createdAt])
  @@index([createdBy])
  @@index([projectId])
  @@index([title])
}

model subcategories {
  id                    String     @id @db.Uuid
  categoryId            String     @db.Uuid
  name                  String     @db.VarChar(100)
  code                  String     @unique @db.VarChar(50)
  description           String?    @db.VarChar(500)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime
  projectsAsSubcategory Project[]  @relation("ProjectSubcategory")
  categories            categories @relation(fields: [categoryId], references: [id])
  types                 types[]

  @@index([categoryId])
  @@index([code])
  @@index([isActive])
}

model types {
  id             String        @id @db.Uuid
  subcategoryId  String        @db.Uuid
  name           String        @db.VarChar(100)
  code           String        @db.VarChar(50)
  description    String?       @db.VarChar(500)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  projectsAsType Project[]     @relation("ProjectType")
  subcategories  subcategories @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@unique([subcategoryId, code])
  @@index([code])
  @@index([isActive])
  @@index([subcategoryId])
}

enum UserRole {
  EMPLOYEE
  TEAM_LEAD
  MANAGER
}

enum ProjectScope {
  DOMESTIC
  OVERSEAS
}

enum ReportType {
  PART_REPORT
  SUMMARY_REPORT
  TEST_LIST
}
