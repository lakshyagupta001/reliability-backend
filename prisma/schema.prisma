generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  EMPLOYEE
  TEAM_LEAD
  MANAGER
}

enum ProjectScope {
  DOMESTIC
  OVERSEAS
}

enum ReportType {
  PART_REPORT
  SUMMARY_REPORT
  TEST_LIST
}

enum ReportStatus {
  GENERATED
  PENDING_REVIEW
  REVIEWED
  PENDING_APPROVAL
  APPROVED
  REVIEW_REJECTED
  APPROVAL_REJECTED
}

// ============================================================================
// MASTER DATA MODELS
// ============================================================================

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subcategories Subcategory[]
  projects      Project[]

  @@index([code])
  @@index([isActive])
  @@map("categories")
}

model Subcategory {
  id          String   @id @default(uuid()) @db.Uuid
  categoryId  String   @db.Uuid
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  projects Project[]
  types    Type[]

  @@index([categoryId])
  @@index([code])
  @@index([isActive])
  @@map("subcategories")
}

model Type {
  id            String   @id @default(uuid()) @db.Uuid
  subcategoryId String   @db.Uuid
  name          String   @db.VarChar(100)
  code          String   @db.VarChar(50)
  description   String?  @db.VarChar(500)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  projects    Project[]

  @@unique([subcategoryId, code])
  @@index([subcategoryId])
  @@index([code])
  @@index([isActive])
  @@map("types")
}

model StatusMaster {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  displayName String   @db.VarChar(100)
  color       String   @default("#6B7280") @db.VarChar(20)
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects      Project[]
  statusHistory ProjectStatusHistory[]

  @@index([code])
  @@index([isActive])
  @@index([isSystem])
  @@map("status_master")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      UserRole @default(EMPLOYEE)
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects          Project[]
  reports           Report[]
  reportsChecked    Report[] @relation("ReportChecker")
  reportsApproved   Report[] @relation("ReportApprover")
  reportApprovalHistory ReportApprovalHistory[]
  authSessions      AuthSession[]
  uploadedDocuments ProjectDocument[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model AuthSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("auth_sessions")
}

// ============================================================================
// PROJECT & DOCUMENTS
// ============================================================================

model Project {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  categoryId    String   @db.Uuid
  subcategoryId String   @db.Uuid
  typeId        String   @db.Uuid
  statusId      String   @db.Uuid
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  location      String   @db.VarChar(255)

  // Basic Details
  partName             String?       @db.VarChar(255)
  modelName            String?       @db.VarChar(255)
  projectPIC           String?       @db.VarChar(255)
  projectScope         ProjectScope?
  applicableCompliance String?       @db.VarChar(500)

  sampleSubmissionDate DateTime? @db.Date
  massProductionDate   DateTime? @db.Date

  partSampleCount    Int?
  productSampleCount Int?

  projectPriorityScale String? @db.VarChar(50)

  // Technical Details
  operatingVoltageRange String? @db.VarChar(100)
  ambientOperatingRange String? @db.VarChar(100)

  iduHardwareVersion String? @db.VarChar(100)
  oduHardwareVersion String? @db.VarChar(100)

  iduFirmwareVersion String? @db.VarChar(100)
  oduFirmwareVersion String? @db.VarChar(100)

  partNumberAndMake           String? @db.Text
  technicalDataSheetReference String? @db.Text

  maximumPipingLength            String? @db.VarChar(100)
  maximumCommunicationWireLength String? @db.VarChar(100)

  oduFanMotorDetails String? @db.Text
  iduFanMotorDetails String? @db.Text

  compressorDetails String? @db.Text

  refrigerantName     String? @db.VarChar(100)
  refrigerantQuantity String? @db.VarChar(50)

  // Status Remark
  statusRemark String? @db.VarChar(1000)

  createdBy String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator       User                   @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  category      Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory   Subcategory            @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)
  type          Type                   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  status        StatusMaster           @relation(fields: [statusId], references: [id], onDelete: Restrict)
  documents     ProjectDocument[]
  statusHistory ProjectStatusHistory[]
  reports       Report[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([typeId])
  @@index([statusId])
  @@index([startDate])
  @@index([endDate])
  @@index([createdBy])
  @@index([name])
  @@map("projects")
}

model ProjectDocument {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @db.Uuid
  fileName     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  fileUrl      String   @db.VarChar(500)
  fileSize     Int?
  mimeType     String?  @db.VarChar(100)
  uploadedBy   String   @db.Uuid
  uploadedAt   DateTime @default(now())

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([uploadedBy])
  @@map("project_documents")
}

model ProjectStatusHistory {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  statusId  String   @db.Uuid
  remark    String?  @db.VarChar(1000)
  changedBy String   @db.Uuid
  changedAt DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status  StatusMaster @relation(fields: [statusId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([statusId])
  @@index([changedAt])
  @@map("project_status_history")
}

// ============================================================================
// REPORTS
// ============================================================================

model Report {
  id           String     @id @default(uuid()) @db.Uuid
  projectId    String     @db.Uuid
  type         ReportType
  title        String     @db.VarChar(255)
  format       String     @db.VarChar(50)
  formatNumber String?    @db.VarChar(100)
  reportNumber String?    @db.VarChar(100)
  data         Json
  status           ReportStatus @default(GENERATED)
  checkedByUserId  String?      @db.Uuid
  checkedByName    String?      @db.VarChar(100)
  approvedByUserId String?      @db.Uuid
  approvedByName   String?      @db.VarChar(100)
  
  // Workflow tracking
  lastActionBy     String?      @db.VarChar(100)
  lastActionType   String?      @db.VarChar(50)
  lastActionAt     DateTime?
  rejectionHistory Json?

  createdBy    String     @db.Uuid
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  checker User?   @relation("ReportChecker", fields: [checkedByUserId], references: [id], onDelete: SetNull)
  approver User?  @relation("ReportApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvalHistory ReportApprovalHistory[]

  @@unique([projectId, type])
  @@index([projectId])
  @@index([format])
  @@index([createdBy])
  @@index([createdAt])
  @@index([title])
  @@map("reports")
}

model ReportApprovalHistory {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @db.Uuid
  userId    String   @db.Uuid
  action    String   @db.VarChar(50)
  status    String   @db.VarChar(50)
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@map("report_approval_history")
}
